#!/usr/bin/env sh
set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
MANIFEST="$ROOT/managed-skills.txt"

failures=0
warnings=0

say() {
  printf '%s\n' "$*"
}

fail() {
  say "ERROR: $*"
  failures=$((failures + 1))
}

warn() {
  say "WARN: $*"
  warnings=$((warnings + 1))
}

check_skill() {
  rel=$1
  path="$ROOT/$rel"
  skill="$path/SKILL.md"

  case "$rel" in
    skills/*) ;;
    *)
      fail "$rel must live under skills/"
      return
      ;;
  esac

  if [ ! -d "$path" ]; then
    fail "$rel is not a directory"
    return
  fi

  if [ ! -f "$skill" ]; then
    fail "$rel is missing SKILL.md"
    return
  fi

  first_line=$(sed -n '1p' "$skill")
  if [ "$first_line" != "---" ]; then
    fail "$rel/SKILL.md must start with YAML frontmatter marker ---"
    return
  fi

  frontmatter=$(sed -n '2,/^---$/p' "$skill")

  if ! printf '%s\n' "$frontmatter" | grep -Eq '^name:[[:space:]]*[^[:space:]].*'; then
    fail "$rel/SKILL.md frontmatter is missing name"
  fi

  if ! printf '%s\n' "$frontmatter" | grep -Eq '^description:[[:space:]]*[^[:space:]].*'; then
    fail "$rel/SKILL.md frontmatter is missing description"
  fi

  lines=$(wc -l < "$skill" | tr -d ' ')
  if [ "$lines" -gt 500 ]; then
    warn "$rel/SKILL.md has $lines lines; consider moving detail into references/"
  fi

  say "OK: $rel"
}

if [ ! -f "$MANIFEST" ]; then
  fail "missing $MANIFEST"
else
  while IFS= read -r line || [ -n "$line" ]; do
    set -- $line

    case "${1:-}" in
      ""|\#*) continue ;;
    esac

    rel=$1
    targets=${2:-}

    if [ -z "$targets" ]; then
      fail "$rel is missing targets"
      continue
    fi

    case ",$targets," in
      *,claude,*|*,codex,*) ;;
      *)
        fail "$rel has no supported targets: $targets"
        ;;
    esac

    check_skill "$rel"
  done < "$MANIFEST"
fi

if [ "$failures" -ne 0 ]; then
  say "Failed with $failures error(s) and $warnings warning(s)."
  exit 1
fi

say "Passed with $warnings warning(s)."
